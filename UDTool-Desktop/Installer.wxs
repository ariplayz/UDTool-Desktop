<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
    <Package Name="UDTool Desktop"
             Manufacturer="Ari Cummings"
             Version="1.0.0.0"
             UpgradeCode="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D">

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

        <MediaTemplate EmbedCab="yes" />

        <!-- Define the installation directory -->
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="UDTool Desktop">
                <Component Id="MainComponent" Guid="B2C3D4E5-F6A7-4B8C-9D0E-1F2A3B4C5D6E">
                    <File Id="UDToolDesktopExe" 
                          Source="$(var.PublishDir)\UDTool-Desktop.exe" 
                          KeyPath="yes">
                        <Shortcut Id="StartMenuShortcut"
                                  Directory="ApplicationProgramsFolder"
                                  Name="UDTool Desktop"
                                  Description="File Management Tool"
                                  WorkingDirectory="INSTALLFOLDER"
                                  Icon="AppIcon.exe"
                                  IconIndex="0"
                                  Advertise="yes" />
                    </File>
                    
                    <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
                    <RemoveFolder Id="INSTALLFOLDER" On="uninstall"/>
                    <RegistryValue Root="HKCU" 
                                  Key="Software\AriCummings\UDToolDesktop" 
                                  Name="installed" 
                                  Type="integer" 
                                  Value="1" 
                                  KeyPath="no"/>
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- Create Start Menu shortcut -->
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="ApplicationProgramsFolder" Name="UDTool Desktop">
                <Component Id="ApplicationShortcut" Guid="D4E5F6A7-B8C9-4D0E-1F2A-3B4C5D6E7F8A">
                    <Shortcut Id="UninstallProduct"
                             Name="Uninstall UDTool Desktop"
                             Description="Uninstalls UDTool Desktop"
                             Target="[System64Folder]msiexec.exe"
                             Arguments="/x [ProductCode]"/>
                    <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
                    <RegistryValue Root="HKCU" 
                                  Key="Software\AriCummings\UDToolDesktop"
                                  Name="installed" 
                                  Type="integer" 
                                  Value="1" 
                                  KeyPath="yes"/>
                </Component>
            </Directory>
        </StandardDirectory>

        <!-- Define features to install -->
        <Feature Id="ProductFeature" Title="UDTool Desktop" Level="1">
            <ComponentRef Id="MainComponent" />
            <ComponentRef Id="ApplicationShortcut" />
        </Feature>
    </Package>

    <!-- Define the icon -->
    <Fragment>
        <Icon Id="AppIcon.exe" SourceFile="$(var.PublishDir)\UDTool-Desktop.exe" />
    </Fragment>
</Wix>

